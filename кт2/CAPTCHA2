    <script>
        function refreshCaptcha() {
            const img = document.getElementById('captchaImg');
            const timestamp = new Date().getTime();
            img.src = 'captcha.php?' + timestamp;
            
            // Добавляем небольшой эффект обновления
            img.style.opacity = '0.5';
            setTimeout(() => {
                img.style.opacity = '1';
            }, 200);
            
            // Очищаем поле ввода при обновлении капчи
            document.getElementById('captcha').value = '';
            document.getElementById('captcha').classList.remove('error');
        }
        
        // Добавляем эффект при клике на поле ввода
        const input = document.getElementById('captcha');
        input.addEventListener('focus', function() {
            this.classList.remove('error');
        });
        
        // Обновляем капчу при загрузке страницы, если была ошибка
        <?php if ($error): ?>
        setTimeout(function() {
            refreshCaptcha();
        }, 500);
        <?php endif; ?>
    </script>
